# Server Configuration
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://localhost:3000

# Security
JWT_SECRET=your_very_long_and_complex_jwt_secret_minimum_32_chars
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=32_byte_encryption_key_for_data_123456

# Database
MONGODB_URI=mongodb://localhost:27017/steel_estimation_secure

# MONGODB_URI=mongodb+srv://kalyanigithub4172_db_user:vdvVsJEVsQE2A8HV@cluster0.dhc3tut.mongodb.net/?appName=Cluster0

# File Upload Security
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=.xlsx,.xls,.csv
UPLOAD_DIR=./secure_uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Excel Processing
EXCEL_SALT=your_excel_processing_salt

# Admin Settings (for price management)
ADMIN_EMAIL=admin@steelestimate.com
ADMIN_PASSWORD_HASH=bcrypt_hash_here